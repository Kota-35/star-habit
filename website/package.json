{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "openapi:generate": "cd ../server && cargo run --bin openapi_gen",
    "api:generate": "pnpm openapi:generate && orval --config ./orval.config.ts",
    "dev:client": "next dev",
    "dev:server": "cd ../server && watchexec -w . -e rs,toml -i target -r -- cargo run --bin server",
    "dev": "concurrently -n server,client -c blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "build": "pnpm openapi:generate && next build",
    "start": "next start",
    "lint": "biome check && pnpm typecheck",
    "lint:fix": "biome check --write && pnpm typecheck",
    "format": "biome format",
    "format:fix": "biome format --write",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.10.0",
    "jotai": "^2.18.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "concurrently": "^9.2.1",
    "orval": "^8.5.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
