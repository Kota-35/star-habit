{
  "openapi": "3.1.0",
  "info": {
    "title": "server",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/auth/signin": {
      "post": {
        "tags": [
          "crate::routes::api::auth::signin"
        ],
        "summary": "既存ユーザーでサインインし、JWT の access/refresh トークンを返す",
        "operationId": "signin",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SigninRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SigninResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized (invalid or expired idToken)"
          },
          "404": {
            "description": "Not Found (user not registered; sign up first)"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/auth/signup": {
      "post": {
        "tags": [
          "crate::routes::api::auth::signup"
        ],
        "summary": "新規ユーザーとプロフィールを登録する",
        "operationId": "signup",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SignupResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request (unsupported or missing sign_in_provider in Firebase ID token)"
          },
          "401": {
            "description": "Unauthorized (missing or invalid idToken in request body)"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SigninRequest": {
        "type": "object",
        "required": [
          "idToken"
        ],
        "properties": {
          "idToken": {
            "type": "string",
            "description": "Firebase Auth で発行された ID トークン（ボディで送信）"
          }
        }
      },
      "SigninResponse": {
        "type": "object",
        "required": [
          "accessToken",
          "refreshToken"
        ],
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "SignupRequest": {
        "type": "object",
        "required": [
          "username",
          "email",
          "idToken"
        ],
        "properties": {
          "email": {
            "type": "string"
          },
          "idToken": {
            "type": "string",
            "description": "Firebase Auth で発行された ID トークン（ボディで送信）"
          },
          "username": {
            "type": "string"
          }
        }
      },
      "SignupResponse": {
        "type": "object",
        "description": "Signup API のレスポンス用 DTO",
        "required": [
          "accessToken",
          "refreshToken"
        ],
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      }
    }
  }
}